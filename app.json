{
  "expo": {
    "name": "FindYourWay",
    "slug": "findyourway",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "n",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Precisamos da sua localização para recomendar lugares próximos.",
        "NSCalendarsUsageDescription": "Precisamos acessar seu calendário para salvar horários de visita."
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbfa4c2d-6483-4a1f-94fd-588870a31bf3"
      }
    },
    "android": {
      "package": "com.nikkpatrikk.boltexponativewind",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#40E0D0"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAprcgWbEpsQNbzMmi17yqe_2213eRzxDQ"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_CALENDAR",
        "WRITE_CALENDAR"
      ]
    },
    "owner": "nikkpatrikk"
  }
}
